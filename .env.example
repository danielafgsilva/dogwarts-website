# --- Sanity CMS ---
# Found in https://www.sanity.io/manage → your project → API
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity Studio (development)
SANITY_STUDIO_PROJECT_ID=your_project_id
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_ORGANIZATION_ID=your_org_id

# Write token used ONLY by scripts/seed-sanity.js (Editor permissions).
# Never expose this in client code.
SANITY_API_TOKEN=your_write_token

# Shared secret for on-demand revalidation. Set the SAME value here and in the
# Sanity webhook (sanity.io/manage → API → Webhooks → Secret). When content is
# published, the webhook hits /api/revalidate and the site updates in seconds.
SANITY_REVALIDATE_SECRET=any_long_random_string

# --- Google reviews ---
# The reviews section pulls the latest reviews live (never from Sanity).
# Two sources are supported; the first one configured wins.
#
# A) Google Business Profile API ("My Business" v4 review-data) — returns ALL
#    reviews, newest first. Needs OAuth (owner authorises once → refresh token)
#    and API access approval from Google. Docs:
#    https://developers.google.com/my-business/content/review-data
GOOGLE_BUSINESS_CLIENT_ID=
GOOGLE_BUSINESS_CLIENT_SECRET=
GOOGLE_BUSINESS_REFRESH_TOKEN=
GOOGLE_BUSINESS_ACCOUNT_ID=
GOOGLE_BUSINESS_LOCATION_ID=
#
# B) Places API (New) — simplest: just an API key + Place ID, up to 5 reviews.
#    Enable "Places API (New)" in Google Cloud. GOOGLE_PLACE_ID can also live in
#    Sanity siteSettings.contact.googlePlaceId. If neither source is configured,
#    the section just links out to the Google profile — nothing breaks.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# --- Contact form email (SMTP via Nodemailer) ---
# The form at /contactos POSTs to /api/contact, which emails the address set in
# Sanity (siteSettings.contact.email). For a Gmail account, create an App
# Password (Google Account → Security → 2-Step Verification → App passwords).
# Defaults: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465.
SMTP_USER=dogwarts.pt@gmail.com
SMTP_PASS=your_gmail_app_password
# Optional overrides:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# MAIL_FROM="Dogwarts <dogwarts.pt@gmail.com>"
