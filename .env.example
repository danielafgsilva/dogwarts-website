# --- Sanity CMS ---
# Found in https://www.sanity.io/manage → your project → API
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity Studio (development)
SANITY_STUDIO_PROJECT_ID=your_project_id
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_ORGANIZATION_ID=your_org_id

# Write token used ONLY by scripts/seed-sanity.js (Editor permissions).
# Never expose this in client code.
SANITY_API_TOKEN=your_write_token

# --- Google reviews (Places API New) ---
# Enable "Places API (New)" in Google Cloud and create an API key.
# GOOGLE_PLACE_ID is the business' Place ID (can also be stored in Sanity
# siteSettings.contact.googlePlaceId, which takes precedence when set).
# When either is missing, the site simply links out to the Google profile
# instead of rendering live review cards — nothing breaks.
GOOGLE_PLACES_API_KEY=your_places_api_key
GOOGLE_PLACE_ID=your_place_id
